        <!-- Formulario con validación HTML5 nativa -->
        <form action="#" method="POST" novalidate>

          <div class="grupo-form">
            <label for="nombre">Nombre completo <span aria-hidden="true">*</span></label>
            <input type="text" id="nombre" name="nombre" required
                   placeholder="Tu nombre completo"
                   autocomplete="name">
          </div>

          <div class="grupo-form">
            <label for="email">Correo electrónico <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" required
                   placeholder="tu@correo.com"
                   autocomplete="email">
          </div>

          <div class="grupo-form">
            <label for="telefono">Teléfono <span aria-hidden="true">*</span></label>
            <input type="tel" id="telefono" name="telefono" required
                   pattern="[0-9]{9,15}"
                   title="Introduce un número de teléfono válido (9–15 dígitos)"
                   placeholder="Ej: 604 21 80 89"
                   autocomplete="tel">
          </div>

          <div class="grupo-form">
            <label for="servicio">Tipo de servicio</label>
            <select id="servicio" name="servicio">
              <option value="" disabled selected>Selecciona un servicio…</option>
              <option value="interiores">Diseño de Interiores</option>
              <option value="mobiliario">Mobiliario a Medida</option>
              <option value="gestion">Gestión de Proyectos</option>
              <option value="reforma">Reforma Integral</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="grupo-form">
            <label for="info">Descripción del proyecto <span aria-hidden="true">*</span></label>
            <textarea id="info" name="info" required
                      placeholder="Describe las necesidades de tu proyecto: tipo de espacio, superficie aproximada, plazos…"></textarea>
          </div>

          <div class="grupo-checkbox">
            <input type="checkbox" id="privacidad" name="privacidad" required>
            <label for="privacidad">
              Acepto la <a href="#">Política de Privacidad</a> y el tratamiento de mis datos para gestionar mi solicitud.
            </label>
          </div>

          <button type="submit" class="btn-primario" style="width:100%;justify-content:center;font-size:1rem;">
            Enviar Solicitud →
          </button>

        </form>
